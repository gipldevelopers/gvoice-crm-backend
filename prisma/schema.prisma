// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id        String   @id @default(uuid())
  name      String
  address   String?
  logo      String?
  gstNo     String?
  users     User[]
  leads     Lead[]
  customers Customer[]
  tasks     Task[]
  deals     Deal[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("companies")
}

model User {
  id         String   @id @default(uuid())
  username   String   @unique
  fullName   String
  email      String   @unique
  phone      String?
  password   String
  department String?
  teamName   String?
  role       String   @default("employee")
  reportsToId String?
  reportsTo  User?    @relation("UserHierarchy", fields: [reportsToId], references: [id], onDelete: SetNull)
  directReports User[] @relation("UserHierarchy")
  token      String?
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])
  files      File[]
  leads      Lead[]   @relation("AssignedLeads")
  leadAuditLogs LeadAuditLog[]
  deals      Deal[]   @relation("AssignedDeals")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, department])
  @@index([companyId, role])
  @@index([reportsToId])
  @@map("users")
}

model File {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  path         String
  size         Int
  mimetype     String
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("files")
}

model Lead {
  id             String   @id @default(uuid())
  name           String
  phone          String
  email          String?
  source         String   // Website, WhatsApp, Referral, Ads, Walk-in
  value          Float    // Lead value in currency
  status         String   @default("New") // New, Contacted, Qualified, Lost
  notes          String?  @db.Text
  salespersonId  String?
  salesperson    User?    @relation("AssignedLeads", fields: [salespersonId], references: [id], onDelete: SetNull)
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer       Customer?
  auditLogs      LeadAuditLog[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("leads")
}

model LeadAuditLog {
  id            String   @id @default(cuid())
  leadId         String
  lead           Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  companyId      String
  actorUserId    String?
  actorUser      User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  action         String   // CREATE, UPDATE, STATUS_CHANGE, ASSIGN_CHANGE, CLAIM_REQUEST, CONVERT_TO_CUSTOMER, DELETE
  changes        Json?
  message        String?
  createdAt      DateTime @default(now())

  @@index([leadId, createdAt])
  @@index([companyId, createdAt])
  @@map("lead_audit_logs")
}

model Customer {
  id             String   @id @default(uuid())
  type           String   @default("Company") // Company, Individual
  name           String
  contactPerson  String?
  email          String
  phone          String
  alternatePhone String?
  gst            String?
  address        String?
  city           String?
  state          String?
  pincode        String?
  notes          String?  @db.Text
  status         String   @default("Active") // Active, Inactive

  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  // Link to the lead this customer came from (optional)
  leadId         String?  @unique
  lead           Lead?    @relation(fields: [leadId], references: [id])

  deals          Deal[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("customers")
}

model Deal {
  id             String   @id @default(uuid())
  title          String
  value          Float
  stage          String   @default("New Deal") // New Deal, Requirement Shared, Quotation Sent, Follow-up, Negotiation, Won, Lost
  closingDate    DateTime?
  probability    Int      @default(10)
  notes          String?  @db.Text
  
  salespersonId  String?
  salesperson    User?    @relation("AssignedDeals", fields: [salespersonId], references: [id], onDelete: SetNull)
  
  customerId     String?
  customer       Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("deals")
}

model Task {
  id          String   @id @default(cuid())
  title       String
  type        String   // Call, Meeting, Email, WhatsApp
  linkedType  String   // Lead, Customer, Deal
  linkedId    String?  // ID of the linked entity
  linkedTo    String?  // Name of the linked entity
  assignedTo  String
  dueDate     DateTime
  dueTime     String
  status      String   @default("Pending") // Pending, Completed
  priority    String   @default("Medium")  // High, Medium, Low
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  
  @@index([companyId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
}
