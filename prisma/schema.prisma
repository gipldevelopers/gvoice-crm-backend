// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id        String   @id @default(uuid())
  name      String
  address   String?
  logo      String?
  gstNo     String?
  users     User[]
  leads     Lead[]
  customers Customer[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("companies")
}

model User {
  id         String   @id @default(uuid())
  username   String   @unique
  fullName   String
  email      String   @unique
  phone      String?
  password   String
  department String?
  role       String   @default("user")
  token      String?
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])
  files      File[]
  leads      Lead[]   @relation("AssignedLeads")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("users")
}

model File {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  path         String
  size         Int
  mimetype     String
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("files")
}

model Lead {
  id             String   @id @default(uuid())
  name           String
  phone          String
  email          String?
  source         String   // Website, WhatsApp, Referral, Ads, Walk-in
  value          Float    // Lead value in currency
  status         String   @default("New") // New, Contacted, Qualified, Lost
  notes          String?  @db.Text
  salespersonId  String?
  salesperson    User?    @relation("AssignedLeads", fields: [salespersonId], references: [id], onDelete: SetNull)
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer       Customer?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("leads")
}

model Customer {
  id             String   @id @default(uuid())
  type           String   @default("Company") // Company, Individual
  name           String
  contactPerson  String?
  email          String
  phone          String
  alternatePhone String?
  gst            String?
  address        String?
  city           String?
  state          String?
  pincode        String?
  notes          String?  @db.Text
  status         String   @default("Active") // Active, Inactive

  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  // Link to the lead this customer came from (optional)
  leadId         String?  @unique
  lead           Lead?    @relation(fields: [leadId], references: [id])

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("customers")
}

